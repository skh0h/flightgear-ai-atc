# FlightGear AI ATC sidecar — example environment configuration.
#
# Copy this file to `.env` and adjust as needed. Every variable below is
# OPTIONAL: the sidecar runs with the documented defaults if a variable is
# unset. Values shown are the defaults baked into sidecar/config.py.
# Uncomment and edit any line you want to override.

# --- Gemini / LLM ---

# API key for Google Gemini. Optional: leave empty to run the fully offline
# code path (no LLM calls). Default: unset (offline).
GEMINI_API_KEY=

# Model id used for fast, low-latency generations. Default: gemini-2.5-flash
# GEMINI_MODEL_FAST=gemini-2.5-flash

# Model id used for higher-quality (slower) generations. Default: gemini-2.5-pro
# GEMINI_MODEL_PRO=gemini-2.5-pro

# --- FlightGear telnet bridge ---

# Hostname FlightGear's telnet/props server listens on. Must not be empty if
# set. Default: localhost
# FG_TELNET_HOST=localhost

# TCP port for FlightGear's telnet/props server. Integer in 1..65535.
# Default: 5501
# FG_TELNET_PORT=5501

# --- Caching ---

# Path to the SQLite airport/groundnet cache database.
# Default: fixtures/cache/airports.sqlite
# CACHE_DB_PATH=fixtures/cache/airports.sqlite

# --- Text to speech ---

# macOS `say` voice used for spoken ATC. Default: Alex
# TTS_VOICE=Alex

# --- Logging ---

# Logging verbosity (DEBUG, INFO, WARNING, ERROR, CRITICAL). Case-insensitive;
# normalized to upper case. Default: INFO
# LOG_LEVEL=INFO

# --- Weather (METAR) ---

# Enable live METAR fetches for wind/runway selection. Set to 0, false, or no
# to disable; any other value enables it. Default: 1 (enabled)
# METAR_ENABLED=1

# --- Session logging ---

# Path to a JSONL session log file. Leave empty to disable session logging.
# Default: unset (off)
# SESSION_LOG_PATH=

# --- AI taxiway labels (advanced / unsafe) ---

# Allow AI-inferred taxiway names in ATC clearances. These are unverified
# guesses — Gemini has no chart/AIRAC grounding — so this is OFF by default to
# keep clearances grounded in real groundnet XML names only. Set to 1, true, or
# yes to enable (unsafe). Default: 0 (disabled)
# AI_TAXIWAY_LABELS=0
