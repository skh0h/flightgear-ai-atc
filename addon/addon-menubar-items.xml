<?xml version="1.0" encoding="UTF-8"?>
<!-- Adds an "AI ATC" menu to the FlightGear menu bar. The panel contains
     all request buttons; menu items beyond Open ATC Panel have been removed. -->
<PropertyList>
  <meta>
    <file-type type="string">FlightGear add-on menu bar items</file-type>
    <format-version type="int">1</format-version>
  </meta>

  <menubar-items>
  <menu>
    <label>AI ATC</label>
    <enabled type="bool">true</enabled>

    <item>
      <label>Open ATC Panel</label>
      <binding>
        <command>nasal</command>
        <script>aiatc.open_dialog();</script>
      </binding>
    </item>

  </menu>
  </menubar-items>
</PropertyList>
