<?xml version="1.0" encoding="UTF-8"?>
<!-- Adds an "AI ATC" menu to the FlightGear menu bar. Request items set the
     /ai-atc/request mailbox props and raise the trigger; the Python sidecar
     polls the trigger, responds, and resets it. -->
<PropertyList>
  <menu>
    <label>AI ATC</label>
    <enabled type="bool">true</enabled>

    <item>
      <label>Open ATC Panel</label>
      <binding>
        <command>dialog-show</command>
        <dialog-name>ai-atc</dialog-name>
      </binding>
    </item>

    <item>
      <label>Request Pushback</label>
      <binding>
        <command>nasal</command>
        <script>
          setprop("/ai-atc/request/type", "pushback");
          setprop("/ai-atc/response/ready", 0);
          setprop("/ai-atc/status", "processing");
          setprop("/ai-atc/request/trigger", 1);
        </script>
      </binding>
    </item>

    <item>
      <label>Request Taxi Clearance</label>
      <binding>
        <command>nasal</command>
        <script>
          setprop("/ai-atc/request/type", "taxi");
          setprop("/ai-atc/response/ready", 0);
          setprop("/ai-atc/status", "processing");
          setprop("/ai-atc/request/trigger", 1);
        </script>
      </binding>
    </item>

    <item>
      <label>Request Takeoff Clearance</label>
      <binding>
        <command>nasal</command>
        <script>
          setprop("/ai-atc/request/type", "takeoff");
          setprop("/ai-atc/response/ready", 0);
          setprop("/ai-atc/status", "processing");
          setprop("/ai-atc/request/trigger", 1);
        </script>
      </binding>
    </item>

    <item>
      <label>Cancel Request</label>
      <binding>
        <command>nasal</command>
        <script>
          setprop("/ai-atc/request/type", "cancel");
          setprop("/ai-atc/request/trigger", 1);
        </script>
      </binding>
    </item>
  </menu>
</PropertyList>
