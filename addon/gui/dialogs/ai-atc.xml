<?xml version="1.0" encoding="UTF-8"?>
<!-- AI ATC dialog: backend status, frequencies, inputs, grouped request buttons, transcript. -->
<PropertyList>
  <name>ai-atc</name>
  <layout>vbox</layout>
  <default-padding type="int">4</default-padding>
  <resizable type="bool">true</resizable>

  <!-- ── Header: title + airport ─────────────────────────────────── -->
  <text>
    <label>AI ATC</label>
    <halign>center</halign>
  </text>
  <group>
    <layout>hbox</layout>
    <halign>center</halign>
    <text>
      <property>/ai-atc/airport/icao</property>
      <live type="bool">true</live>
    </text>
    <text><label>  </label></text>
    <text>
      <property>/ai-atc/airport/name</property>
      <live type="bool">true</live>
    </text>
  </group>

  <!-- Live controller persona name, published by the sidecar. -->
  <text>
    <property>/ai-atc/controller/name</property>
    <live type="bool">true</live>
    <format>Controller: %s</format>
    <halign>center</halign>
  </text>

  <!-- ── Backend status (key "feels broken" fix) + ATC status ────── -->
  <text>
    <property>/ai-atc/backend</property>
    <live type="bool">true</live>
    <format>Backend: %s</format>
    <halign>left</halign>
  </text>
  <text>
    <property>/ai-atc/status</property>
    <live type="bool">true</live>
    <format>Status:  %s</format>
    <halign>left</halign>
  </text>
  <!-- Live flight phase published by the sidecar to /ai-atc/flight-phase. -->
  <text>
    <property>/ai-atc/flight-phase</property>
    <live type="bool">true</live>
    <format>Phase:   %s</format>
    <halign>left</halign>
  </text>
  <!-- Mode B: live ground-traffic sequencing summary written by the sidecar. -->
  <text>
    <property>/ai-atc/traffic/summary</property>
    <live type="bool">true</live>
    <format>Traffic: %s</format>
    <halign>left</halign>
  </text>
  <!-- Live ambient-chatter line published by the sidecar to /ai-atc/chatter. -->
  <text>
    <property>/ai-atc/chatter</property>
    <live type="bool">true</live>
    <format>Chatter: %s</format>
    <halign>left</halign>
  </text>
  <!-- Live airspace class + advisory published by the add-on's publish_airspace().
       The sidecar also reads these for the airspace_check request. -->
  <text>
    <property>/ai-atc/airspace/class</property>
    <live type="bool">true</live>
    <format>Airspace: %s</format>
    <halign>left</halign>
  </text>
  <text>
    <property>/ai-atc/airspace/warning</property>
    <live type="bool">true</live>
    <format>%s</format>
    <halign>left</halign>
  </text>

  <!-- ── Interaction mode (normal / student / checkride) ─────────── -->
  <!-- Each button writes /ai-atc/mode via aiatc.set_mode("..."); the sidecar
       reads it to add coaching (student) or readback-prompt (checkride) nuance. -->
  <group>
    <layout>hbox</layout>
    <default-padding type="int">4</default-padding>
    <text><label>Mode:</label></text>
    <button>
      <legend>Normal</legend>
      <pref-width type="int">75</pref-width>
      <binding>
        <command>nasal</command>
        <script>aiatc.set_mode("normal");</script>
      </binding>
    </button>
    <button>
      <legend>Student</legend>
      <pref-width type="int">75</pref-width>
      <binding>
        <command>nasal</command>
        <script>aiatc.set_mode("student");</script>
      </binding>
    </button>
    <button>
      <legend>Checkride</legend>
      <pref-width type="int">85</pref-width>
      <binding>
        <command>nasal</command>
        <script>aiatc.set_mode("checkride");</script>
      </binding>
    </button>
    <text>
      <property>/ai-atc/mode</property>
      <live type="bool">true</live>
      <format>  (%s)</format>
    </text>
  </group>

  <!-- ── Frequencies ─────────────────────────────────────────────── -->
  <group>
    <layout>hbox</layout>
    <default-padding type="int">4</default-padding>
    <text>
      <property>/ai-atc/airport/freq/ground</property>
      <live type="bool">true</live>
      <format>GND: %s</format>
    </text>
    <text>
      <property>/ai-atc/airport/freq/tower</property>
      <live type="bool">true</live>
      <format>  TWR: %s</format>
    </text>
    <text>
      <property>/ai-atc/airport/freq/atis</property>
      <live type="bool">true</live>
      <format>  ATIS: %s</format>
    </text>
    <text>
      <property>/ai-atc/airport/freq/approach</property>
      <live type="bool">true</live>
      <format>  APP: %s</format>
    </text>
    <text>
      <property>/ai-atc/airport/freq/departure</property>
      <live type="bool">true</live>
      <format>  DEP: %s</format>
    </text>
  </group>

  <!-- ── Active runways (Mode A) ─────────────────────────────────── -->
  <!-- Static PUI XML cannot generate a checkbox per dynamic runway slot, so we
       expose the first two runway slots (the common single/parallel-runway
       case). Each checkbox is bound live to /ai-atc/airport/runway[i]/active and
       its <binding> re-normalises the toggled state to "1"/"0" via
       aiatc.set_runway_active(i, ...). The adjacent live <text> shows the actual
       runway id for that slot. Any further runway slots default to active "1"
       (published by publish_airport_data) and are simply not toggleable here. -->
  <group>
    <layout>hbox</layout>
    <default-padding type="int">4</default-padding>
    <text><label>Active runways:</label></text>
    <checkbox>
      <property>/ai-atc/airport/runway[0]/active</property>
      <live type="bool">true</live>
      <binding>
        <command>nasal</command>
        <script>aiatc.set_runway_active(0, getprop("/ai-atc/airport/runway[0]/active"));</script>
      </binding>
    </checkbox>
    <text>
      <property>/ai-atc/airport/runway[0]/id</property>
      <live type="bool">true</live>
    </text>
    <text><label>   </label></text>
    <checkbox>
      <property>/ai-atc/airport/runway[1]/active</property>
      <live type="bool">true</live>
      <binding>
        <command>nasal</command>
        <script>aiatc.set_runway_active(1, getprop("/ai-atc/airport/runway[1]/active"));</script>
      </binding>
    </checkbox>
    <text>
      <property>/ai-atc/airport/runway[1]/id</property>
      <live type="bool">true</live>
    </text>
  </group>
  <text>
    <label>(Unchecked = runway closed for this session; other runways default active.)</label>
    <halign>left</halign>
  </text>

  <!-- ── Inputs: callsign + runway ───────────────────────────────── -->
  <group>
    <layout>hbox</layout>
    <default-padding type="int">4</default-padding>
    <text><label>Callsign:</label></text>
    <input>
      <property>/ai-atc/request/callsign</property>
      <live type="bool">true</live>
      <pref-width type="int">100</pref-width>
    </input>
    <text><label>  Runway:</label></text>
    <input>
      <property>/ai-atc/request/runway</property>
      <live type="bool">true</live>
      <pref-width type="int">60</pref-width>
    </input>
  </group>

  <!-- ── Departure buttons ───────────────────────────────────────── -->
  <group>
    <layout>hbox</layout>
    <default-padding type="int">4</default-padding>
    <halign>center</halign>
    <text><label>Departure:</label></text>
    <button>
      <legend>IFR Clearance</legend>
      <pref-width type="int">110</pref-width>
      <binding>
        <command>nasal</command>
        <script>aiatc.request("ifr_clearance");</script>
      </binding>
    </button>
    <button>
      <legend>Pushback</legend>
      <pref-width type="int">80</pref-width>
      <binding>
        <command>nasal</command>
        <script>aiatc.request("pushback");</script>
      </binding>
    </button>
    <button>
      <legend>Taxi</legend>
      <pref-width type="int">60</pref-width>
      <binding>
        <command>nasal</command>
        <script>aiatc.request("taxi");</script>
      </binding>
    </button>
    <button>
      <legend>Takeoff</legend>
      <pref-width type="int">70</pref-width>
      <binding>
        <command>nasal</command>
        <script>aiatc.request("takeoff");</script>
      </binding>
    </button>
    <button>
      <legend>Intersection Dep</legend>
      <pref-width type="int">120</pref-width>
      <binding>
        <command>nasal</command>
        <script>aiatc.request("intersection_departure");</script>
      </binding>
    </button>
  </group>

  <!-- ── Arrival buttons ─────────────────────────────────────────── -->
  <group>
    <layout>hbox</layout>
    <default-padding type="int">4</default-padding>
    <halign>center</halign>
    <text><label>Arrival:  </label></text>
    <button>
      <legend>Approach</legend>
      <pref-width type="int">75</pref-width>
      <binding>
        <command>nasal</command>
        <script>aiatc.request("approach");</script>
      </binding>
    </button>
    <button>
      <legend>ILS</legend>
      <pref-width type="int">45</pref-width>
      <binding>
        <command>nasal</command>
        <script>aiatc.request("ils");</script>
      </binding>
    </button>
    <button>
      <legend>Field in Sight</legend>
      <pref-width type="int">100</pref-width>
      <binding>
        <command>nasal</command>
        <script>aiatc.request("airfield_in_sight");</script>
      </binding>
    </button>
    <button>
      <legend>LAHSO</legend>
      <pref-width type="int">70</pref-width>
      <binding>
        <command>nasal</command>
        <script>aiatc.request("lahso");</script>
      </binding>
    </button>
    <button>
      <legend>Radio Check</legend>
      <pref-width type="int">90</pref-width>
      <binding>
        <command>nasal</command>
        <script>aiatc.request("radio_check");</script>
      </binding>
    </button>
  </group>

  <!-- ── Arrival clearance / flow buttons ────────────────────────── -->
  <!-- Phase-aware request tokens consumed by the sidecar:
       arrival_clearance, holding, expect_approach, flow_control. -->
  <group>
    <layout>hbox</layout>
    <default-padding type="int">4</default-padding>
    <halign>center</halign>
    <text><label>          </label></text>
    <button>
      <legend>Arrival Clrnc</legend>
      <pref-width type="int">110</pref-width>
      <binding>
        <command>nasal</command>
        <script>aiatc.request("arrival_clearance");</script>
      </binding>
    </button>
    <button>
      <legend>Holding</legend>
      <pref-width type="int">75</pref-width>
      <binding>
        <command>nasal</command>
        <script>aiatc.request("holding");</script>
      </binding>
    </button>
    <button>
      <legend>Expect Apch</legend>
      <pref-width type="int">100</pref-width>
      <binding>
        <command>nasal</command>
        <script>aiatc.request("expect_approach");</script>
      </binding>
    </button>
    <button>
      <legend>Flow Control</legend>
      <pref-width type="int">100</pref-width>
      <binding>
        <command>nasal</command>
        <script>aiatc.request("flow_control");</script>
      </binding>
    </button>
  </group>

  <!-- ── Emergency / abnormal buttons ────────────────────────────── -->
  <!-- Split across two hbox rows so the nine request buttons fit the dialog
       width. Each button fires aiatc.request("<token>") exactly like the
       Departure/Arrival groups; the sidecar maps the token to phraseology. -->
  <group>
    <layout>hbox</layout>
    <default-padding type="int">4</default-padding>
    <halign>center</halign>
    <text><label>Emergency:</label></text>
    <button>
      <legend>Mayday</legend>
      <pref-width type="int">70</pref-width>
      <binding>
        <command>nasal</command>
        <script>aiatc.request("mayday");</script>
      </binding>
    </button>
    <button>
      <legend>Pan-Pan</legend>
      <pref-width type="int">70</pref-width>
      <binding>
        <command>nasal</command>
        <script>aiatc.request("pan_pan");</script>
      </binding>
    </button>
    <button>
      <legend>Gear Emergency</legend>
      <pref-width type="int">115</pref-width>
      <binding>
        <command>nasal</command>
        <script>aiatc.request("gear_emergency");</script>
      </binding>
    </button>
    <button>
      <legend>Min Fuel</legend>
      <pref-width type="int">75</pref-width>
      <binding>
        <command>nasal</command>
        <script>aiatc.request("min_fuel");</script>
      </binding>
    </button>
    <button>
      <legend>Diversion</legend>
      <pref-width type="int">85</pref-width>
      <binding>
        <command>nasal</command>
        <script>aiatc.request("diversion");</script>
      </binding>
    </button>
  </group>
  <group>
    <layout>hbox</layout>
    <default-padding type="int">4</default-padding>
    <halign>center</halign>
    <text><label>          </label></text>
    <button>
      <legend>Go-Around</legend>
      <pref-width type="int">85</pref-width>
      <binding>
        <command>nasal</command>
        <script>aiatc.request("go_around");</script>
      </binding>
    </button>
    <button>
      <legend>Sq 7500</legend>
      <pref-width type="int">70</pref-width>
      <binding>
        <command>nasal</command>
        <script>aiatc.request("squawk_7500");</script>
      </binding>
    </button>
    <button>
      <legend>Sq 7600</legend>
      <pref-width type="int">70</pref-width>
      <binding>
        <command>nasal</command>
        <script>aiatc.request("squawk_7600");</script>
      </binding>
    </button>
    <button>
      <legend>Sq 7700</legend>
      <pref-width type="int">70</pref-width>
      <binding>
        <command>nasal</command>
        <script>aiatc.request("squawk_7700");</script>
      </binding>
    </button>
  </group>

  <!-- ── Briefings / airspace info ───────────────────────────────── -->
  <!-- Request tokens consumed by the sidecar: simbrief, fss_briefing, ctaf,
       airspace_check. Each fires aiatc.request("<token>") exactly like the
       Departure/Arrival groups; the sidecar maps the token to phraseology. -->
  <group>
    <layout>hbox</layout>
    <default-padding type="int">4</default-padding>
    <halign>center</halign>
    <text><label>Briefings:</label></text>
    <button>
      <legend>SimBrief</legend>
      <pref-width type="int">90</pref-width>
      <binding>
        <command>nasal</command>
        <script>aiatc.request("simbrief");</script>
      </binding>
    </button>
    <button>
      <legend>FSS Brief</legend>
      <pref-width type="int">90</pref-width>
      <binding>
        <command>nasal</command>
        <script>aiatc.request("fss_briefing");</script>
      </binding>
    </button>
    <button>
      <legend>CTAF</legend>
      <pref-width type="int">70</pref-width>
      <binding>
        <command>nasal</command>
        <script>aiatc.request("ctaf");</script>
      </binding>
    </button>
    <button>
      <legend>Airspace</legend>
      <pref-width type="int">90</pref-width>
      <binding>
        <command>nasal</command>
        <script>aiatc.request("airspace_check");</script>
      </binding>
    </button>
  </group>

  <!-- ── Transcript ──────────────────────────────────────────────── -->
  <textbox>
    <name>atc-log</name>
    <rows type="int">10</rows>
    <cols type="int">60</cols>
    <editable type="bool">false</editable>
    <slider type="int">15</slider>
    <property>/ai-atc/log</property>
    <live type="bool">true</live>
    <stretch type="bool">true</stretch>
  </textbox>

  <!-- ── Readback (Phase 5 push-to-talk) ─────────────────────────── -->
  <!-- Type the readback for the latest clearance and submit it for grading.
       The input is live-bound to /ai-atc/readback/heard; "Submit Readback"
       fires aiatc.request("readback") (also bound to Ctrl+R via aiatc.ptt()).
       The sidecar grades it and writes /ai-atc/readback/result, shown live. -->
  <group>
    <layout>hbox</layout>
    <default-padding type="int">4</default-padding>
    <text><label>Readback:</label></text>
    <input>
      <property>/ai-atc/readback/heard</property>
      <live type="bool">true</live>
      <pref-width type="int">260</pref-width>
    </input>
    <button>
      <legend>Submit Readback</legend>
      <pref-width type="int">120</pref-width>
      <binding>
        <command>nasal</command>
        <script>aiatc.request("readback");</script>
      </binding>
    </button>
  </group>
  <text>
    <property>/ai-atc/readback/result</property>
    <live type="bool">true</live>
    <format>Readback: %s</format>
    <halign>left</halign>
  </text>

  <!-- ── About + Close ───────────────────────────────────────────── -->
  <text>
    <label>AI ATC — open-source add-on for FlightGear. Not affiliated with any real ATC service.</label>
    <halign>center</halign>
  </text>
  <group>
    <layout>hbox</layout>
    <halign>center</halign>
    <button>
      <legend>Close</legend>
      <pref-width type="int">60</pref-width>
      <binding>
        <command>dialog-close</command>
        <dialog-name>ai-atc</dialog-name>
      </binding>
    </button>
  </group>

</PropertyList>
