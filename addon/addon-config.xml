<?xml version="1.0" encoding="UTF-8"?>
<!-- Default property values and key bindings for the AI ATC addon. -->
<PropertyList>
  <!-- Mailbox defaults initialised at addon load (see addon-main.nas). -->
  <ai-atc>
    <request>
      <type type="string">taxi</type>
      <callsign type="string"></callsign>
      <runway type="string"></runway>
      <trigger type="bool">false</trigger>
    </request>
    <response>
      <text type="string"></text>
      <ready type="bool">false</ready>
    </response>
    <status type="string">idle</status>
    <log type="string"></log>
  </ai-atc>

  <!-- Ctrl+Shift+T fires a taxi request without opening the dialog. -->
  <input>
    <keyboard>
      <key n="20">
        <name>Ctrl-Shift-T</name>
        <desc>AI ATC: request taxi clearance</desc>
        <mod-ctrl type="bool">true</mod-ctrl>
        <binding>
          <command>nasal</command>
          <script>aiatc.request("taxi");</script>
        </binding>
      </key>
    </keyboard>
  </input>
</PropertyList>
