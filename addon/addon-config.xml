<?xml version="1.0" encoding="UTF-8"?>
<!-- Default property values and key bindings for the AI ATC addon. -->
<PropertyList>
  <!-- Mailbox defaults initialised at addon load (see addon-main.nas). -->
  <ai-atc>
    <request>
      <type type="string">taxi</type>
      <callsign type="string"></callsign>
      <runway type="string"></runway>
      <trigger type="bool">false</trigger>
    </request>
    <response>
      <text type="string"></text>
      <ready type="bool">false</ready>
    </response>
    <status type="string">idle</status>
    <log type="string"></log>
    <!-- Push-to-talk readback mailbox (Phase 5). /readback/heard holds the
         pilot's typed/spoken readback; the sidecar grades it on a "readback"
         request and writes a human result to /readback/result. -->
    <readback>
      <heard type="string"></heard>
      <result type="string"></result>
    </readback>
  </ai-atc>

  <!-- Key bindings (fire without opening the dialog):
         Ctrl+Shift+T  (n=20) — request taxi clearance
         Ctrl+R        (n=18) — push-to-talk: submit the current readback -->
  <input>
    <keyboard>
      <key n="20">
        <name>Ctrl-Shift-T</name>
        <desc>AI ATC: request taxi clearance</desc>
        <mod-ctrl type="bool">true</mod-ctrl>
        <binding>
          <command>nasal</command>
          <script>aiatc.request("taxi");</script>
        </binding>
      </key>
      <key n="18">
        <name>Ctrl-R</name>
        <desc>AI ATC: push-to-talk — submit readback (/ai-atc/readback/heard)</desc>
        <mod-ctrl type="bool">true</mod-ctrl>
        <binding>
          <command>nasal</command>
          <script>aiatc.ptt();</script>
        </binding>
      </key>
    </keyboard>
  </input>
</PropertyList>
